{
  "rules": {

    ".read": false,
    ".write": false,

    "incidents": {
      ".read": "auth != null",
      ".indexOn": ["agencyId", "closedAt", "startedAt"],
      "$incidentId": {
        ".write": "auth != null",

        "agencyId":        { ".validate": "newData.isString() && newData.val().length <= 50" },
        "title":           { ".validate": "newData.isString() && newData.val().length <= 200" },
        "type":            { ".validate": "newData.isString() && newData.val().length <= 50" },
        "startedAt":       { ".validate": "newData.isNumber()" },
        "lastActivityAt":  { ".validate": "newData.isNumber()" },
        "createdBy":       { ".validate": "newData.isString() && newData.val().length <= 100" },
        "closedAt":        { ".validate": "newData.val() === null || newData.isNumber()" },
        "closedBy":        { ".validate": "newData.isString() && newData.val().length <= 100" },

        "incident": {
          "$field": { ".validate": "newData.isString() && newData.val().length <= 5000" }
        },

        "damages": {
          "$teamId": {
            ".validate": "$teamId.length <= 50",
            "$field": { ".validate": "newData.isNumber() || (newData.isString() && newData.val().length <= 200)" }
          }
        },

        "mobilizations": {
          "$teamId": {
            ".validate": "$teamId.length <= 50"
          }
        },

        "actions": {
          "$actionId": {
            "content":  { ".validate": "newData.isString() && newData.val().length <= 5000" },
            "teamId":   { ".validate": "newData.isString() && newData.val().length <= 50" },
            "author":   { ".validate": "newData.isString() && newData.val().length <= 100" },
            "timestamp":{ ".validate": "newData.isNumber()" }
          }
        },

        "casualties": {
          "$cardId": {
            "name":     { ".validate": "newData.isString() && newData.val().length <= 100" },
            "age":      { ".validate": "newData.isString() && newData.val().length <= 30" },
            "gender":   { ".validate": "newData.isString() && newData.val().length <= 10" },
            "symptom":  { ".validate": "newData.isString() && newData.val().length <= 1000" },
            "hospital": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "notes":    { ".validate": "newData.isString() && newData.val().length <= 3000" },
            "$other":   { ".validate": true }
          }
        },

        "mciCasualties": {
          "$cardId": {
            "name":       { ".validate": "newData.isString() && newData.val().length <= 100" },
            "age":        { ".validate": "newData.isString() && newData.val().length <= 30" },
            "gender":     { ".validate": "newData.isString() && newData.val().length <= 10" },
            "location":   { ".validate": "newData.isString() && newData.val().length <= 500" },
            "triage":     { ".validate": "newData.isString() && newData.val().length <= 30" },
            "consciousness": { ".validate": "newData.isString() && newData.val().length <= 30" },
            "rr":         { ".validate": "newData.val() === '' || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 200) || (newData.isString() && newData.val().length <= 10)" },
            "pulse":      { ".validate": "newData.val() === '' || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 300) || (newData.isString() && newData.val().length <= 10)" },
            "bpSys":      { ".validate": "newData.val() === '' || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 400) || (newData.isString() && newData.val().length <= 10)" },
            "bpDia":      { ".validate": "newData.val() === '' || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 300) || (newData.isString() && newData.val().length <= 10)" },
            "spo2":       { ".validate": "newData.val() === '' || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 100) || (newData.isString() && newData.val().length <= 10)" },
            "symptom":    { ".validate": "newData.isString() && newData.val().length <= 1000" },
            "mechanism":  { ".validate": "newData.isString() && newData.val().length <= 100" },
            "drugs":      { ".validate": "newData.isString() && newData.val().length <= 500" },
            "hospital":   { ".validate": "newData.isString() && newData.val().length <= 100" },
            "departTime": { ".validate": "newData.isString() && newData.val().length <= 10" },
            "arriveTime": { ".validate": "newData.isString() && newData.val().length <= 10" },
            "notes":      { ".validate": "newData.isString() && newData.val().length <= 3000" },
            "$other":     { ".validate": true }
          }
        }
      }
    },

    "archives": {
      ".read":  "auth != null",
      ".write": "auth != null",
      ".indexOn": ["archivedAt"]
    },

    "config": {
      "agencyCodes": {
        ".read":  "auth != null",
        ".write": "auth != null",
        "$codeId": {
          "code": { ".validate": "newData.isString() && newData.val().length <= 50" },
          "id":   { ".validate": "newData.isString() && newData.val().length <= 50" },
          "name": { ".validate": "newData.isString() && newData.val().length <= 50" },
          "role": { ".validate": "newData.isString() && (newData.val() === 'normal' || newData.val() === 'observer' || newData.val() === 'admin' || newData.val() === 'display')" }
        }
      }
    },

    "mci2": {

