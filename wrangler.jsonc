{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mci",
  // worker.js: /api/ocr (Claude Vision 중계) 처리, 나머지는 정적 자산 서빙
  "main": "worker.js",
  "compatibility_date": "2026-05-21",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
